{
    "name":        "blessed-xterm",
    "homepage":    "http://github.com/rse/blessed-xterm",
    "description": "XTerm Widget for Blessed Curses Environment",
    "version":     "1.5.1",
    "license":     "MIT",
    "author": {
        "name":    "Dr. Ralf S. Engelschall",
        "email":   "rse@engelschall.com",
        "url":     "http://engelschall.com"
    },
    "keywords": [
        "blessed", "terminal", "widget", "xterm", "pty"
    ],
    "repository": {
        "type": "git",
        "url":  "git://github.com/rse/blessed-xterm.git"
    },
    "bugs": {
        "url":  "http://github.com/rse/blessed-xterm/issues"
    },
    "devDependencies": {
        "eslint":                                    "10.7.0",
        "@eslint/js":                                "10.0.1",
        "@stylistic/eslint-plugin":                  "5.10.0",
        "eslint-plugin-n":                           "18.2.2",
        "eslint-plugin-promise":                     "7.3.0",
        "globals":                                   "17.7.0"
    },
    "dependencies" : {
        "clone":                                     "2.1.2",
        "blessed":                                   "0.1.81",
        "jsdom":                                     "25.0.0",
        "xterm":                                     "2.8.1",
        "node-pty":                                  "1.0.0"
    },
    "engines": {
        "node":                                      ">=20.19.0"
    },
    "allowScripts": {
        "node-pty":                                  true
    },
    "upd": [ "!xterm" ],
    "scripts": {
        "prepublishOnly": "npm run lint",
        "lint":           "eslint --config eslint.mjs blessed-xterm.js sample.js",
        "test":           "node sample.js"
    },
    "main": "./blessed-xterm.js"
}
